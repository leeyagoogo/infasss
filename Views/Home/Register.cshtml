@model INFASS.Models.User

@{
    ViewData["Title"] = "Register";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="container-fluid auth-container">

    <div class="row auth-card">

        <!-- FORM / RIGHT PANEL -->
        <div class="col-lg-6 right-panel">
            <h2>SIGN UP</h2>
            <p class="subtitle">Create your account</p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <form asp-action="Register" method="post">
                <div class="mb-3">
                    <input asp-for="Username" class="form-control custom-input" placeholder="Username" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <input asp-for="Email" class="form-control custom-input" placeholder="Email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <input asp-for="Password" type="password" class="form-control custom-input" placeholder="Password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <input asp-for="ConfirmPassword" type="password" class="form-control custom-input" placeholder="Confirm Password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button class="btn login-btn w-100" type="submit">SIGN UP</button>
            </form>

            <div class="text-center mt-4">
                Already have an account?
                <a asp-action="Login">Login</a>
            </div>
        </div>

        <!-- GREEN SIDE -->
        <div class="col-lg-6 left-panel d-none d-lg-flex">
            <img src="/assets/img/avataaars.svg" class="avatar mb-4" alt="avatar" />
            <h1>START BOOTSTRAP</h1>
            <hr class="divider">
            <p>Join our community!</p>
        </div>

        <!-- Show left panel below form on small screens -->
        <div class="col-12 d-lg-none left-panel">
            <img src="/assets/img/avataaars.svg" class="avatar mb-4" alt="avatar" />
            <h1>Start Bootstrap</h1>
            <hr class="divider">
            <p>Join our community!</p>
        </div>

    </div>

</div>