@model INFASS.Models.User

@{
    ViewData["Title"] = "Login";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="container-fluid auth-container">

    <div class="row auth-card">

        <!-- LEFT PANEL -->
        <div class="col-lg-6 left-panel d-none d-lg-flex">
            <img src="/assets/img/avataaars.svg" class="avatar mb-4" alt="avatar" />
            <h1>START BOOTSTRAP</h1>
            <hr class="divider">
            <p>Graphic Artist - Web Designer - Illustrator.</p>
        </div>

        <!-- RIGHT PANEL -->
        <div class="col-lg-6 right-panel">
            <h2>LOGIN</h2>
            <p class="subtitle">Welcome back! Login to continue.</p>

            <form asp-action="Login" method="post">
                <div class="mb-4">
                    <input asp-for="Username" class="form-control custom-input" placeholder="Username" />
                </div>

                <div class="mb-4">
                    <input asp-for="Password" type="password" class="form-control custom-input" placeholder="Password" />
                </div>

                <button class="btn login-btn w-100" type="submit">LOGIN</button>
            </form>

            <div class="text-center mt-4">
                Don't have an account?
                <a asp-action="Register">Register</a>
            </div>
        </div>

        <!-- Show left panel below form on small screens -->
        <div class="col-12 d-lg-none left-panel">
            <img src="/assets/img/avataaars.svg" class="avatar mb-4" alt="avatar" />
            <h1>Start Bootstrap</h1>
            <hr class="divider">
            <p>Graphic Artist - Web Designer - Illustrator.</p>
        </div>

    </div>

</div>